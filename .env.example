# GPU Spot Lotto — Environment Variables
# Copy to .env and fill in actual values

# Redis
REDIS_URL=redis://localhost:6379

# Kubernetes
K8S_MODE=dry-run          # dry-run | live
CLUSTER_PREFIX=gpu-lotto-dev

# Spot Regions
SPOT_REGIONS=us-east-1,us-east-2,us-west-2

# Price Watcher
PRICE_MODE=mock           # mock | live
POLL_INTERVAL=30

# Auth
AUTH_ENABLED=false

# Dispatch
DISPATCH_MODE=rule        # rule | agent
# AGENT_MODEL=global.anthropic.claude-sonnet-4-6

# Logging
LOG_LEVEL=info

# Claude Code Notifications (optional)
# CLAUDE_NOTIFY_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
