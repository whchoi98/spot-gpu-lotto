            "default": "models"
          }
        },
        "type": "object",
        "required": [
          "filename"
        ],
        "title": "PresignRequest"
      },
      "TemplateEntry": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "image": {
            "type": "string",
            "title": "Image"
          },
          "instance_type": {
            "type": "string",
            "title": "Instance Type",
            "default": "g6.xlarge"
          },
          "gpu_count": {
            "type": "integer",
            "title": "Gpu Count",
            "default": 1
          },
          "gpu_type": {
            "type": "string",
            "title": "Gpu Type",
            "default": "l4"
          },
          "storage_mode": {
            "type": "string",
            "title": "Storage Mode",
            "default": "s3"
