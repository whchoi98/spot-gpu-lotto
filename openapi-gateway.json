            "default": 1
          },
          "storage_mode": {
            "type": "string",
            "title": "Storage Mode",
            "default": "s3"
          },
          "checkpoint_enabled": {
            "type": "boolean",
            "title": "Checkpoint Enabled",
            "default": false
          },
          "webhook_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
