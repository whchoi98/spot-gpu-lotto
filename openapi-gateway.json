            "type": "integer",
            "title": "Capacity"
          }
        },
        "type": "object",
        "required": [
          "capacity"
        ],
        "title": "CapacityUpdate"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JobRequest": {
        "properties": {
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          },
          "image": {
            "type": "string",
            "title": "Image",
            "default": "nvidia/cuda:12.0-base"
          },
          "command": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Command",
            "default": [
